# Copie para .env e preencha.
DATABASE_URL=sqlite+aiosqlite:///./sac.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# CSV de inscrições (caminho absoluto ou relativo ao cwd ao rodar import)
FORMS_CSV_PATH=../frontend/forms.csv

# POST /api/admin/import-forms — obrigatório: cabeçalho X-Import-Secret com este valor
IMPORT_FORMS_SECRET=

# CORS (separar por vírgula)
CORS_ORIGINS=http://localhost:5173

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=

# OTP
OTP_EXPIRE_MINUTES=15
OTP_PEPPER=change-me-otp-pepper

# IMG BB
IMGBB_KEY=